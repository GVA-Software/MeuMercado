{
  "name": "meumercado",
  "version": "0.0.0",
  "private": true,
  "description": "Meu Mercado — app de economia em compras de supermercado (PWA). 100% open-source, sem API paga.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:packages": "npm run build -w @meumercado/domain -w @meumercado/contracts",
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run build:packages && concurrently -k -n api,web -c blue,magenta \"npm run dev -w @meumercado/api\" \"npm run dev -w @meumercado/mobile\"",
    "start": "cross-env NODE_ENV=production npm run start -w @meumercado/api",
    "start:prod": "npm run build && npm run start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  }
}
