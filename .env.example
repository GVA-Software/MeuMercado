# ==========================================================================
# meuMercado — variáveis de ambiente (EXEMPLO)
# Copie para `.env` e preencha. NUNCA commite o `.env` real (está no .gitignore).
# ==========================================================================

# ---- Geral ----
NODE_ENV=development

# ---- API (NestJS) ----
API_PORT=3000
# Origens permitidas no CORS (separadas por vírgula). Sem "*" em produção.
CORS_ORIGINS=http://localhost:5173

# ---- Banco (PostgreSQL + PostGIS) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=meumercado
POSTGRES_USER=meumercado
POSTGRES_PASSWORD=troque-esta-senha
# Usuário de MENOR privilégio usado pela aplicação (não use o superuser)
DATABASE_URL=postgres://meumercado:troque-esta-senha@localhost:5432/meumercado

# ---- Redis (cache, rate-limit, pub/sub) ----
REDIS_URL=redis://localhost:6379

# ---- Autenticação (scaffold — usado a partir da camada Waze) ----
# Gere segredos fortes: `openssl rand -base64 48`
JWT_ACCESS_SECRET=troque-por-um-segredo-forte
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte
JWT_ACCESS_TTL=900          # 15 min (segundos)
JWT_REFRESH_TTL=1209600     # 14 dias (segundos)

# ---- Cloudflare Turnstile (CAPTCHA grátis) ----
TURNSTILE_SECRET_KEY=
# (a chave pública/site key vai no front, como VITE_TURNSTILE_SITE_KEY)

# ---- Rate limiting (Throttler) ----
RATE_LIMIT_TTL=60           # janela em segundos
RATE_LIMIT_MAX=120          # requisições por janela por IP

# ---- Motores de geo (auto-hospedados, sem API paga) ----
VALHALLA_URL=http://localhost:8002
PHOTON_URL=http://localhost:2322
NOMINATIM_URL=http://localhost:8080
TILES_URL=http://localhost:8081

# ---- Pipeline de dados OSM (dev) ----
# Extrato regional do Geofabrik (pequeno, cabe em dev). Ex.: um estado do Brasil.
OSM_EXTRACT_URL=https://download.geofabrik.de/south-america/brazil/sudeste-latest.osm.pbf

# ==========================================================================
# Front-end (Vite) — variáveis expostas ao navegador começam com VITE_
# Coloque estas em apps/mobile/.env (ou aqui se rodar tudo junto)
# ==========================================================================
VITE_API_BASE_URL=http://localhost:3000
VITE_TILES_URL=http://localhost:8081
VITE_TURNSTILE_SITE_KEY=
# Centro inicial do mapa (lng,lat) e zoom — ajuste para sua região do extrato
VITE_MAP_DEFAULT_CENTER=-46.6333,-23.5505
VITE_MAP_DEFAULT_ZOOM=12
