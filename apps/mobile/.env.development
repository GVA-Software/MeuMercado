# DEV: a PWA (Vite :5173) fala com a API em outra origem (:3000).
VITE_API_BASE_URL=http://localhost:3000

# Login com Google (opcional). Cole o Client ID do OAuth "Web application" (é PÚBLICO,
# o MESMO do back GOOGLE_CLIENT_ID). Vazio => botão "Entrar com Google" fica oculto.
VITE_GOOGLE_CLIENT_ID=

# Cloudflare Turnstile (anti-robô, grátis). Site key é PÚBLICA (par do back
# TURNSTILE_SECRET_KEY). Vazio => o desafio some do login/cadastro (dev).
VITE_TURNSTILE_SITE_KEY=
