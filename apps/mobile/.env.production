# PROD: a PWA é servida pela própria API (mesma origem). Base vazia => usa /api relativo.
VITE_API_BASE_URL=

# Login com Google (opcional). MESMO Client ID do back (GOOGLE_CLIENT_ID). Público.
# No Render pode ser setado como env de build (sobrescreve este). Vazio => botão oculto.
VITE_GOOGLE_CLIENT_ID=

# Cloudflare Turnstile (anti-robô, grátis). Site key PÚBLICA (par do back
# TURNSTILE_SECRET_KEY). No Render pode vir como env de build. Vazio => desafio oculto.
VITE_TURNSTILE_SITE_KEY=
